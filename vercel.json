{
    "version": 2,
    "buildCommand": "npm run vercel-build",
    "installCommand": "npm install",
    "framework": "vite",
    "outputDirectory": "dist/",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*[.]vcl$)",
            "destination": "/index.html"
        },
        {
            "source": "/((?!api/|assets/).*)",
            "destination": "/index.html"
        }
    ]
}