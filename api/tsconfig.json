{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2022",
        "outDir": "../dist-api",
        "rootDir": "../",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "../api/**/*",
        "../server/**/*"
    ]
}