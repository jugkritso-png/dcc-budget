{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ES2022",
        "outDir": "../dist-api",
        "rootDir": "../",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "NodeNext",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "../api/**/*",
        "../server/**/*"
    ]
}