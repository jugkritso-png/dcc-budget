{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(authenticated)/layout,_N_T_/(authenticated)/request/layout,_N_T_/(authenticated)/request/page,_N_T_/request"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGF1dGhlbnRpY2F0ZWQp/request/__PAGE__",
    "/!KGF1dGhlbnRpY2F0ZWQp/request",
    "/!KGF1dGhlbnRpY2F0ZWQp",
    "/_index",
    "/_head"
  ]
}