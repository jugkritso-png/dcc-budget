{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(authenticated)/layout,_N_T_/(authenticated)/requests/layout,_N_T_/(authenticated)/requests/page,_N_T_/requests"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGF1dGhlbnRpY2F0ZWQp/requests/__PAGE__",
    "/!KGF1dGhlbnRpY2F0ZWQp/requests",
    "/!KGF1dGhlbnRpY2F0ZWQp",
    "/_index",
    "/_head"
  ]
}